{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",

  "_comment": [
    "ARM template — deploys one Logic App Standard resource with two workflows.",
    "",
    "Deploy with:",
    "  az deployment group create \\",
    "    --resource-group <rg> \\",
    "    --template-file logic_apps/arm-deploy.json \\",
    "    --parameters \\",
    "        logicAppName=rag-ingestion-la \\",
    "        location=eastus \\",
    "        sharepointSiteUrl='https://<tenant>.sharepoint.com/sites/<site>' \\",
    "        sharepointFolder='Shared Documents' \\",
    "        domain=hr \\",
    "        ingestionAgentUrl='https://<aca-ingestion-agent-fqdn>' \\",
    "        logicAppSecret='<same-as-LOGIC_APP_WEBHOOK_SECRET>'",
    "",
    "After deploying:",
    "  1. Go to the Logic App resource → Connections blade.",
    "  2. Authenticate the 'sharepointonline' API connection using a service account",
    "     that has 'Sites.Read.All' access to the SharePoint site(s).",
    "  3. Enable both workflows (upsert-workflow, delete-workflow).",
    "  4. Set LOGIC_APP_WEBHOOK_SECRET in your Ingestion Agent .env / ACA secrets.",
    "",
    "Per-site deployment:",
    "  Deploy one instance of this template per SharePoint site / domain combination.",
    "  Change the 'domain' parameter to match (hr, legal, it, ops).",
    "  All instances can share the same Ingestion Agent URL and secret."
  ],

  "parameters": {
    "logicAppName": {
      "type": "string",
      "metadata": { "description": "Name for the Logic App Standard resource." }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": { "description": "Azure region. Must match your other resources." }
    },
    "sharepointSiteUrl": {
      "type": "string",
      "metadata": { "description": "Full SharePoint site URL, e.g. https://corp.sharepoint.com/sites/HR" }
    },
    "sharepointFolder": {
      "type": "string",
      "defaultValue": "Shared Documents",
      "metadata": { "description": "Document library folder to watch (top-level or subfolder)." }
    },
    "domain": {
      "type": "string",
      "defaultValue": "hr",
      "allowedValues": ["hr", "legal", "it", "ops"],
      "metadata": { "description": "Business domain — maps to the Domain enum in shared/models.py" }
    },
    "ingestionAgentUrl": {
      "type": "string",
      "metadata": { "description": "Base URL of the Ingestion Agent container app, no trailing slash." }
    },
    "logicAppSecret": {
      "type": "securestring",
      "metadata": { "description": "Shared secret for X-Logic-App-Secret header. Must match LOGIC_APP_WEBHOOK_SECRET." }
    }
  },

  "variables": {
    "sharepointConnectionName": "sharepointonline",
    "sharepointConnectionId": "[resourceId('Microsoft.Web/connections', variables('sharepointConnectionName'))]"
  },

  "resources": [

    {
      "type": "Microsoft.Web/connections",
      "apiVersion": "2016-06-01",
      "name": "[variables('sharepointConnectionName')]",
      "location": "[parameters('location')]",
      "properties": {
        "displayName": "SharePoint Online",
        "api": {
          "id": "[subscriptionResourceId('Microsoft.Web/locations/managedApis', parameters('location'), 'sharepointonline')]"
        }
      },
      "comments": "API connection shell — authenticate it manually after deployment (Step 2 above)."
    },

    {
      "type": "Microsoft.Logic/workflows",
      "apiVersion": "2019-05-01",
      "name": "[parameters('logicAppName')]",
      "location": "[parameters('location')]",
      "dependsOn": [
        "[variables('sharepointConnectionId')]"
      ],
      "properties": {
        "state": "Enabled",
        "definition": {
          "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
          "contentVersion": "1.0.0.0",
          "parameters": {
            "$connections": { "defaultValue": {}, "type": "Object" },
            "sharepointSiteUrl": { "defaultValue": "[parameters('sharepointSiteUrl')]", "type": "String" },
            "sharepointFolder":  { "defaultValue": "[parameters('sharepointFolder')]",  "type": "String" },
            "domain":            { "defaultValue": "[parameters('domain')]",            "type": "String" },
            "ingestionAgentUrl": { "defaultValue": "[parameters('ingestionAgentUrl')]", "type": "String" },
            "logicAppSecret":    { "defaultValue": "",                                  "type": "SecureString" }
          },
          "triggers": {
            "When_a_file_is_created_or_modified": {
              "type": "ApiConnection",
              "recurrence": { "frequency": "Minute", "interval": 5 },
              "splitOn": "@triggerBody()",
              "inputs": {
                "host": {
                  "connection": { "name": "@parameters('$connections')['sharepointonline']['connectionId']" }
                },
                "method": "get",
                "path": "/datasets/@{encodeURIComponent(encodeURIComponent(parameters('sharepointSiteUrl')))}/triggers/onupdatedfile",
                "queries": {
                  "folderId": "@parameters('sharepointFolder')",
                  "includeFileContent": false,
                  "inferContentType": true
                }
              }
            }
          },
          "actions": {
            "Get_file_content": {
              "type": "ApiConnection",
              "runAfter": {},
              "inputs": {
                "host": {
                  "connection": { "name": "@parameters('$connections')['sharepointonline']['connectionId']" }
                },
                "method": "get",
                "path": "/datasets/@{encodeURIComponent(encodeURIComponent(parameters('sharepointSiteUrl')))}/files/@{encodeURIComponent(triggerBody()?['Id'])}/content",
                "queries": { "inferContentType": false }
              }
            },
            "Send_to_Ingestion_Agent": {
              "type": "Http",
              "runAfter": { "Get_file_content": ["Succeeded"] },
              "inputs": {
                "method": "POST",
                "uri": "@{parameters('ingestionAgentUrl')}/ingest/from-logic-app",
                "headers": {
                  "Content-Type": "application/json",
                  "X-Logic-App-Secret": "@parameters('logicAppSecret')"
                },
                "body": {
                  "doc_name": "@triggerBody()?['Name']",
                  "doc_url":  "@triggerBody()?['Path']",
                  "domain":   "@parameters('domain')",
                  "file_type": "@{last(split(triggerBody()?['Name'], '.'))}",
                  "file_content_base64": "@{base64(body('Get_file_content'))}",
                  "is_delete": false
                },
                "retryPolicy": {
                  "type": "exponential",
                  "count": 4,
                  "interval": "PT10S",
                  "minimumInterval": "PT10S",
                  "maximumInterval": "PT1H"
                }
              }
            }
          }
        },
        "parameters": {
          "$connections": {
            "value": {
              "sharepointonline": {
                "connectionId": "[variables('sharepointConnectionId')]",
                "connectionName": "[variables('sharepointConnectionName')]",
                "id": "[subscriptionResourceId('Microsoft.Web/locations/managedApis', parameters('location'), 'sharepointonline')]"
              }
            }
          },
          "logicAppSecret": { "value": "[parameters('logicAppSecret')]" }
        }
      }
    }

  ],

  "outputs": {
    "logicAppId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Logic/workflows', parameters('logicAppName'))]"
    }
  }
}
