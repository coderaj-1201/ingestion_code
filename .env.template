# ── ingestion-pipeline / .env.template ───────────────────────────────────────
# Copy this file to .env and fill in every value marked <...>.
# Never commit .env — it is in .gitignore.
#
# For production (Azure Container Apps) set these as ACA secrets / environment
# variables instead of a .env file. The names are identical.
#
# How to find each value is documented inline.
# =============================================================================


# =============================================================================
# AZURE AI FOUNDRY
# =============================================================================

# Portal:  AI Foundry → your project → Overview → "Project endpoint"
# CLI:     az cognitiveservices account show \
#              --name <hub> --resource-group <rg> \
#              --query properties.endpoint -o tsv
AZURE_FOUNDRY_PROJECT_ENDPOINT=https://<hub>.services.ai.azure.com/api/projects/<project>

# Portal:  AI Foundry → your project → Deployments tab → model name
# The embedding model must be text-embedding-3-large or text-embedding-ada-002.
# The light LLM is used for page cleaning and table summarisation (cheap/fast).
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
AZURE_OPENAI_LIGHT_LLM_DEPLOYMENT=gpt-4.1-mini
AZURE_OPENAI_API_VERSION=2024-08-01-preview


# =============================================================================
# AZURE BLOB STORAGE
# =============================================================================

# Portal:  Storage account → Overview → Storage account name  (just the name)
AZURE_STORAGE_ACCOUNT_NAME=<storage-account-name>

# Container names — create these before first run:
#   az storage container create --name raw-documents   --account-name <name>
#   az storage container create --name processed-chunks --account-name <name>
AZURE_STORAGE_CONTAINER_RAW=raw-documents
AZURE_STORAGE_CONTAINER_PROCESSED=processed-chunks


# =============================================================================
# AZURE AI SEARCH
# =============================================================================

# Portal:  AI Search resource → Overview → Url
AZURE_SEARCH_ENDPOINT=https://<search-resource-name>.search.windows.net

# Portal:  AI Search → Settings → Keys → Primary admin key
# Production: leave blank and grant the ACA Managed Identity "Search Index Data Contributor"
#             on the Search resource instead (RUNNING_IN_AZURE=true switches to MI auth).
AZURE_SEARCH_API_KEY=<primary-admin-key>

# The index must exist before the Embedding Agent runs.
# Create it with:  python infra/create_search_index.py
AZURE_SEARCH_INDEX=idx-rag
AZURE_SEARCH_SEMANTIC_CONFIG=rag-semantic-config


# =============================================================================
# AZURE SERVICE BUS
# =============================================================================

# LOCAL DEV — use a connection string (one of the two below, not both):
#   Portal: Service Bus namespace → Shared access policies → RootManageSharedAccessKey
#           → Primary connection string
# PRODUCTION — leave AZURE_SERVICE_BUS_CONNECTION_STR blank and set the namespace
#   instead; Managed Identity (RUNNING_IN_AZURE=true) handles auth automatically.

AZURE_SERVICE_BUS_CONNECTION_STR=Endpoint=sb://<namespace>.servicebus.windows.net/;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=<key>
AZURE_SERVICE_BUS_NAMESPACE=<namespace>.servicebus.windows.net

# Queue names — create these before first run:
#   az servicebus queue create --name ingestion-queue  --namespace-name <ns> --resource-group <rg>
#   az servicebus queue create --name processing-queue --namespace-name <ns> --resource-group <rg>
#   az servicebus queue create --name embedding-queue  --namespace-name <ns> --resource-group <rg>
SB_QUEUE_INGESTION=ingestion-queue
SB_QUEUE_PROCESSING=processing-queue
SB_QUEUE_EMBEDDING=embedding-queue


# =============================================================================
# LOGIC APPS INTEGRATION  (replaces SharePoint Graph direct connectivity)
# =============================================================================

# Shared secret between Logic App and the Ingestion Agent.
# The Logic App sends this in the X-Logic-App-Secret header on every request.
# Generate:  openssl rand -hex 32
# Set the SAME value in the Logic App parameter store (logicAppSecret parameter).
LOGIC_APP_WEBHOOK_SECRET=<generate-with-openssl-rand-hex-32>


# =============================================================================
# MICROSOFT GRAPH / SHAREPOINT  (legacy — only needed for /ingest/folder)
# =============================================================================
# These settings are OPTIONAL when Logic Apps handles all SharePoint connectivity.
# Only set them if you use the manual POST /ingest/folder endpoint or the
# legacy /webhook/sharepoint endpoint.
#
# Portal: Entra ID → App registrations → your app → Overview
# Required API permissions: Sites.Read.All (application permission)

SHAREPOINT_TENANT_ID=<tenant-id>
SHAREPOINT_CLIENT_ID=<app-client-id>

# Portal: Entra ID → App registrations → your app → Certificates & secrets → New client secret
SHAREPOINT_CLIENT_SECRET=<client-secret-value>

# Used only by the legacy webhook endpoint to verify incoming notifications.
SHAREPOINT_WEBHOOK_SECRET=<random-string-at-least-32-chars>

# Comma-separated SharePoint site URLs to watch (legacy webhook path only).
# Format: https://<tenant>.sharepoint.com/sites/<site1>,https://<tenant>.sharepoint.com/sites/<site2>
SHAREPOINT_SITE_URLS=

# Maps each site URL to a domain: <site-url>:<domain>,...
# Example: https://corp.sharepoint.com/sites/HR:hr,https://corp.sharepoint.com/sites/Legal:legal
SITE_DOMAIN_MAP=


# =============================================================================
# PROCESSING TUNING  (defaults work for most deployments)
# =============================================================================

# Child chunks are what get embedded and searched.
# Parent chunks provide surrounding context during retrieval.
CHILD_CHUNK_MAX_TOKENS=200
PARENT_CHUNK_MAX_TOKENS=1000

# Fraction of page height treated as header/footer margin (excluded from text).
HEADER_FOOTER_MARGIN_PCT=0.07


# =============================================================================
# OBSERVABILITY
# =============================================================================

# Portal: Application Insights → Overview → Connection String
# Leave blank to disable App Insights (logs still go to stdout as structured JSON).
APPLICATIONINSIGHTS_CONNECTION_STRING=

LOG_LEVEL=INFO


# =============================================================================
# RUNTIME FLAG  (set automatically by Azure Container Apps)
# =============================================================================

# Set to any non-empty value when running in Azure.
# Controls credential selection: ManagedIdentity (Azure) vs AzureCliCredential (local).
# Azure Container Apps sets this automatically via the Dockerfile ENV — do NOT set
# this in .env; only set it in the ACA environment variables panel if needed.
# RUNNING_IN_AZURE=true
